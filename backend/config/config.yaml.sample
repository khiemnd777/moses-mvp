server:
  host: "0.0.0.0"
  port: 8080
postgres:
  dsn: "postgres://legal:legal@localhost:5433/legal_rag?sslmode=disable"
qdrant:
  url: "http://localhost:6333"
  collection: "legal_chunks"
openai:
  api_key: "YOUR_OPENAI_API_KEY"
  embeddings_model: "text-embedding-3-small"
  chat_model: "gpt-4.1-mini"
storage:
  root_dir: "./data/uploads"
ingest:
  default_segmenter: "free_text"
  chunk_size: 800
  chunk_overlap: 100
prompts:
  guard: "config/prompts/guard.yaml"
  tone_default: "config/prompts/tone_default.yaml"
  tone_academic: "config/prompts/tone_academic.yaml"
  tone_procedure: "config/prompts/tone_procedure.yaml"
vector_repair:
  enabled: true
  interval: 30s
  max_tasks_per_pass: 20

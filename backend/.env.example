CONFIG_PATH=config/config.yaml
SERVER_HOST=0.0.0.0
JWT_SECRET=replace-with-secure-secret
ADMIN_BOOTSTRAP_PASSWORD=replace-with-secure-password
PORT=8080
POSTGRES_IMAGE=postgres:15
POSTGRES_USER=legal
POSTGRES_PASSWORD=legal
POSTGRES_DB=legal_rag
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
DOCKER_POSTGRES_HOST=postgres
DOCKER_POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable
POSTGRES_DATA_DIR=../data/postgres
QDRANT_IMAGE=qdrant/qdrant:v1.9.3
QDRANT_HOST=localhost
QDRANT_PORT=6333
DOCKER_QDRANT_HOST=qdrant
QDRANT_COLLECTION=legal_chunks
QDRANT_STORAGE_DIR=../data/qdrant
OPENAI_API_KEY=replace-with-openai-key
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini
STORAGE_ROOT_DIR=./data/uploads
DOCKER_STORAGE_ROOT_DIR=/app/data/uploads
UPLOADS_DATA_DIR=../data/uploads
INGEST_DEFAULT_SEGMENTER=free_text
INGEST_CHUNK_SIZE=800
INGEST_CHUNK_OVERLAP=100
GUARD_PROMPT_PATH=config/prompts/guard.yaml
TONE_DEFAULT_PROMPT_PATH=config/prompts/tone_default.yaml
TONE_ACADEMIC_PROMPT_PATH=config/prompts/tone_academic.yaml
TONE_PROCEDURE_PROMPT_PATH=config/prompts/tone_procedure.yaml
VECTOR_REPAIR_ENABLED=true
VECTOR_REPAIR_INTERVAL=30s
VECTOR_REPAIR_MAX_TASKS_PER_PASS=20
CORS_ALLOWED_ORIGINS=http://localhost:5173

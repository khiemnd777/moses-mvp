#!/usr/bin/env bash

# repo
export APP_ROOT="/opt/legal_api/app"
export GIT_REPO_URL="git@github.com:your-org/legal_api.git"
export GIT_BRANCH="main"
# export GIT_COMMIT_SHA=""

# backend
export SERVER_HOST="0.0.0.0"
export BACKEND_PORT="8080"
export JWT_SECRET="replace-with-secure-secret"
export ADMIN_BOOTSTRAP_PASSWORD="replace-with-secure-password"
export POSTGRES_IMAGE="postgres:15"
export POSTGRES_USER="legal"
export POSTGRES_PASSWORD="legal"
export POSTGRES_DB="legal_rag"
export POSTGRES_HOST="localhost"
export POSTGRES_PORT="5433"
export DOCKER_POSTGRES_HOST="postgres"
export DOCKER_POSTGRES_PORT="5432"
export POSTGRES_SSLMODE="disable"
# export DATABASE_URL=""
export POSTGRES_DATA_DIR="/var/lib/legal_api/postgres"
export QDRANT_IMAGE="qdrant/qdrant:v1.9.3"
export QDRANT_HOST="localhost"
export QDRANT_PORT="6333"
export DOCKER_QDRANT_HOST="qdrant"
export QDRANT_COLLECTION="legal_chunks"
export QDRANT_STORAGE_DIR="/var/lib/legal_api/qdrant"
export OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
export OPENAI_EMBEDDINGS_MODEL="text-embedding-3-small"
export OPENAI_CHAT_MODEL="gpt-4.1-mini"
export STORAGE_ROOT_DIR="/app/data/uploads"
export DOCKER_STORAGE_ROOT_DIR="/app/data/uploads"
export UPLOADS_DATA_DIR="/var/lib/legal_api/uploads"
export INGEST_DEFAULT_SEGMENTER="free_text"
export INGEST_CHUNK_SIZE="800"
export INGEST_CHUNK_OVERLAP="100"
export GUARD_PROMPT_PATH="config/prompts/guard.yaml"
export TONE_DEFAULT_PROMPT_PATH="config/prompts/tone_default.yaml"
export TONE_ACADEMIC_PROMPT_PATH="config/prompts/tone_academic.yaml"
export TONE_PROCEDURE_PROMPT_PATH="config/prompts/tone_procedure.yaml"
export VECTOR_REPAIR_ENABLED="true"
export VECTOR_REPAIR_INTERVAL="30s"
export VECTOR_REPAIR_MAX_TASKS_PER_PASS="20"
export CORS_ALLOWED_ORIGINS="http://localhost:5173,https://ai.dailyturning.com"

# frontend build
export VITE_API_BASE_URL="https://ai.dailyturning.com"
# export VITE_ADMIN_API_KEY=""
# export VITE_ADMIN_BEARER_TOKEN=""

# nginx + ssl
export DOMAIN="ai.dailyturning.com"
export FRONTEND_ROOT="/var/www/ai.dailyturning.com"
export BACKEND_UPSTREAM="http://127.0.0.1:8080"
export LETSENCRYPT_EMAIL="admin@dailyturning.com"
export ENABLE_SSL="1"
